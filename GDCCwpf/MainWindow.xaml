<Window x:Class="GDCCwpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:GDCCwpf.ViewModels"
        Title="Калькулятор стоимости" 
        Height="350" 
        Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.DataContext>
        <viewModels:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="Калькулятор стоимости разработки"
                   FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Программисты -->
        <Label Grid.Row="1" Grid.Column="0" Content="Программисты:"/>
        <TextBox Grid.Row="1" Grid.Column="1" 
                 Text="{Binding Programmers, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Художники -->
        <Label Grid.Row="2" Grid.Column="0" Content="Художники:"/>
        <TextBox Grid.Row="2" Grid.Column="1" 
                 Text="{Binding Artists, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Месяцы -->
        <Label Grid.Row="3" Grid.Column="0" Content="Месяцев:"/>
        <TextBox Grid.Row="3" Grid.Column="1" 
                 Text="{Binding Months, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Кнопка -->
        <Button Grid.Row="4" Grid.ColumnSpan="2" 
                Content="Рассчитать"
                Command="{Binding CalculateCommand}"
                Height="35"
                Margin="0,15,0,0"/>

        <!-- Результат -->
        <Border Grid.Row="5" Grid.ColumnSpan="2" 
                BorderBrush="#CCCCCC" BorderThickness="1"
                CornerRadius="5"
                Margin="0,10,0,0"
                Padding="10">
            <TextBlock Text="{Binding Result}"
                       FontSize="14" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
